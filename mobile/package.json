{
  "name": "korean-learn-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --go --localhost",
    "ios": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --ios --go --localhost",
    "ipad": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --ios --go --localhost",
    "android": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --android",
    "web": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.0",
    "expo-document-picker": "~13.0.3",
    "expo-font": "~13.0.4",
    "expo-speech": "~13.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "^0.76.9",
    "react-native-safe-area-context": "4.12.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
