{
  "name": "korean-learn-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --go --localhost",
    "ios": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --ios --go --localhost",
    "ipad": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --ios --go --localhost",
    "android": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --android",
    "web": "NODE_OPTIONS=--require=./scripts/expo-node-polyfill.cjs expo start --web",
    "build:android:apk": "npx eas-cli build -p android --profile preview",
    "build:android:aab": "npx eas-cli build -p android --profile production",
    "build:ios:preview": "npx eas-cli build -p ios --profile preview",
    "build:ios:simulator": "npx eas-cli build -p ios --profile preview-simulator",
    "build:ios:production": "npx eas-cli build -p ios --profile production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "expo": "^56.0.0",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-speech": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~5.9.2"
  }
}
